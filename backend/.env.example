# SRIMCA AI Backend - Environment Variables
# Copy this to .env and fill in your values
# Get HF_TOKEN from https://huggingface.co/settings/tokens (free signup)

# Hugging Face Token (for sentence-transformers model downloads, higher limits)
HF_TOKEN=your_huggingface_token_here

# MongoDB Atlas (get from Atlas > Connect > your connection string)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/srimca_ai?retryWrites=true&w=majority
MONGODB_DB_NAME=srimca_ai

# Firebase (Project Settings > Service Accounts > Generate new private key)
FIREBASE_PROJECT_ID=srimcaai
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_FULL_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# JWT (generate secure random string, keep secret)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production_now
JWT_EXPIRATION_HOURS=24

# Flask Server
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
CORS_ORIGINS=*

# OpenAI (optional, for GPT fallback in AI)
OPENAI_API_KEY=your_openai_key_here_optional

# SMTP Email for OTP / verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=2025mca006@gmail.com   
SMTP_PASS=ocgqypybbfuudsiz       
SMTP_FROM=2025mca006@gmail.com   
# SMTP_SENDER_EMAIL and SMTP_SENDER_PASSWORD are also supported.

