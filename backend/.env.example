# SRIMCA AI Backend - Environment Variables Template
# Copy to .env and fill with your values

# MongoDB Atlas (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/srimca_ai?retryWrites=true&w=majority
MONGODB_DB_NAME=srimca_ai

# Firebase Admin SDK (Optional - for email verification fallback)
FIREBASE_PROJECT_ID=srimcaai
FIREBASE_PRIVATE_KEY_ID=your_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_MULTILINE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@project.iam.gserviceaccount.com

# JWT (Required)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production_32+chars
JWT_EXPIRATION_HOURS=24

# SMTP Email (REQUIRED for OTP registration)
SMTP_SENDER_EMAIL=your-verified@gmail.com
SMTP_SENDER_PASSWORD=abcd efgh ijkl mnop  # Gmail App Password (16 chars, spaces shown for clarity - NO SPACES in actual)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# HuggingFace (Recommended for AI chat)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Free from https://huggingface.co/settings/tokens

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# CORS (for Flutter app)
CORS_ORIGINS=*

# Render.com auto
PYTHON_VERSION=3.11.0
